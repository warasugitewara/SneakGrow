{
    "version": "2.0.0",
    "type": "shell",
    "options": {
        "shell": {
            "executable": "powershell.exe",
            "args": ["-NoLogo", "-NoProfile", "-ExecutionPolicy", "Bypass", "-Command"]
        }
    },
    "tasks": [
        {
            "label": "Build Plugin",
            "type": "shell",
            "command": "powershell",
            "args": [
                "mvn package;",
                "& '${workspaceFolder}\\.run\\build.ps1';"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Start Server",
            "type": "shell",
            "command": "java -Xmx1G -Xms1G -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005 -jar paper.jar --nogui",
            "options": {
                "cwd": "${workspaceFolder}/run"
            },
            "isBackground": true,
            "problemMatcher": {
                "owner": "java-debug-server",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^Listening for transport dt_socket at",
                    "endsPattern": "^Listening for transport dt_socket at"
                }
            },
            "dependsOn": [
                "Build Plugin",
            ]
        }
    ]
}